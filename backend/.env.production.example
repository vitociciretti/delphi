# Delphi production env — TEMPLATE. Copy to .env.production (gitignored) and fill in.
# The server holds NO LLM/Zep keys — those are bring-your-own, per request.

# REQUIRED. Signs the anonymous workspace cookie. Generate a strong unique value:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-64-hex-string

FLASK_DEBUG=false
COOKIE_SECURE=true      # cookie sent only over HTTPS (behind nginx/TLS)
TRUST_PROXY=true        # real client IP/scheme from nginx X-Forwarded-*

# --- Optional compute caps (defaults shown; tune to your VPS) ---
# MAX_CONCURRENT_SIMULATIONS=4
# MAX_CONCURRENT_SIMULATIONS_PER_WORKSPACE=1
# MAX_SIMULATION_ROUNDS=50
# MAX_SIMULATION_AGENTS=50
# SIMULATION_MAX_WALLCLOCK_SECONDS=3600
# GUNICORN_THREADS=16
